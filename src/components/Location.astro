---
import SectionHeader from "./SectionHeader.astro";
import { site } from "../data/site";

const hasPhone = site.contact.phone.length > 0;
const hasEmail = site.contact.email.length > 0;
const hasWhatsapp = site.contact.whatsapp.length > 0;
const hasMapsEmbed = site.contact.mapsEmbed.length > 0;
---

<section id="dove-siamo" class="py-20 px-4">
  <div class="max-w-6xl mx-auto">
    <SectionHeader
      title={site.location.title}
      subtitle={site.location.subtitle}
    />

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Info contatti -->
      <div class="space-y-6">
        <!-- Indirizzo -->
        <div class="flex items-start gap-4">
          <div class="text-primary shrink-0 mt-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold">Indirizzo</h3>
            <p class="text-base-content/70">
              {site.contact.address || "Centro, Battipaglia (SA)"}
              <br />
              {site.contact.cap && `${site.contact.cap} `}{site.contact.city} ({site.contact.province})
            </p>
          </div>
        </div>

        <!-- Telefono -->
        {(hasPhone || !hasPhone) && (
          <div class="flex items-start gap-4">
            <div class="text-primary shrink-0 mt-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold">Telefono</h3>
              {hasPhone ? (
                <a href={`tel:${site.contact.phone}`} class="link link-primary">
                  {site.contact.phone}
                </a>
              ) : (
                <p class="text-base-content/50 italic text-sm">Da configurare in site.ts</p>
              )}
            </div>
          </div>
        )}

        <!-- Email -->
        <div class="flex items-start gap-4">
          <div class="text-primary shrink-0 mt-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold">Email</h3>
            {hasEmail ? (
              <a href={`mailto:${site.contact.email}`} class="link link-primary">
                {site.contact.email}
              </a>
            ) : (
              <p class="text-base-content/50 italic text-sm">Da configurare in site.ts</p>
            )}
          </div>
        </div>

        <!-- WhatsApp -->
        {hasWhatsapp && (
          <div class="flex items-start gap-4">
            <div class="text-primary shrink-0 mt-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold">WhatsApp</h3>
              <a
                href={`https://wa.me/${site.contact.whatsapp.replace(/\D/g, "")}`}
                class="link link-primary"
                target="_blank"
                rel="noopener noreferrer"
              >
                Scrivici su WhatsApp
              </a>
            </div>
          </div>
        )}
      </div>

      <!-- Mappa -->
      <div class="rounded-xl overflow-hidden shadow-md aspect-[4/3] lg:aspect-auto lg:min-h-[350px]">
        {hasMapsEmbed ? (
          <iframe
            src={site.contact.mapsEmbed}
            class="w-full h-full border-0"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title={`Mappa di ${site.name} a ${site.city}`}
          ></iframe>
        ) : (
          /* Placeholder mappa — sostituire con iframe Google Maps configurando
             site.contact.mapsEmbed in src/data/site.ts con URL tipo:
             https://www.google.com/maps/embed?pb=YOUR_EMBED_CODE */
          <div
            class="w-full h-full flex items-center justify-center"
            style="background: linear-gradient(135deg, oklch(0.92 0 0) 0%, oklch(0.85 0.02 200) 100%);"
            role="img"
            aria-label={`Mappa di ${site.name} nel centro di ${site.city}`}
          >
            <div class="text-center text-base-content/40">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
              </svg>
              <p class="text-sm font-medium">Google Maps</p>
              <p class="text-xs mt-1">Configura mapsEmbed in site.ts</p>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
