---
import { site } from "../data/site";
---

<section class="hero min-h-[90vh] relative overflow-hidden">
  <!-- Background gradient (sostituire con immagine reale quando disponibile) -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(135deg, oklch(0.637 0.292 12) 0%,  oklch(0.637 0.292 12) 60%,oklch(0.985 0 0) 100%);"
    aria-hidden="true"
  >
    <!-- Overlay pattern sottile -->
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 25% 25%, white 1px, transparent 1px); background-size: 40px 40px;" aria-hidden="true"></div>
  </div>

  <div class="hero-content text-center relative z-10 px-4 py-20">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight">
        {site.hero.title}
      </h1>
      <p class="mt-6 text-lg md:text-xl text-white/85 max-w-2xl mx-auto leading-relaxed">
        {site.hero.subtitle}
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={site.hero.ctaPrimary.href}
          class="btn btn-lg bg-white text-primary hover:bg-white/90 border-0 shadow-lg"
        >
          {site.hero.ctaPrimary.label}
        </a>
        <a
          href={site.hero.ctaSecondary.href}
          class="btn btn-lg btn-outline border-white text-white hover:bg-white/10 hover:border-white"
        >
          {site.hero.ctaSecondary.label}
        </a>
      </div>
    </div>
  </div>
</section>
