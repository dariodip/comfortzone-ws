---
interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<div class="text-center mb-12">
  <h2 class="text-3xl md:text-4xl font-bold">{title}</h2>
  <p class="mt-4 text-lg text-base-content/70 max-w-2xl mx-auto leading-relaxed">
    {subtitle}
  </p>
</div>
