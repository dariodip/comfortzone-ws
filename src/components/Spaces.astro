---
import SectionHeader from "./SectionHeader.astro";
import { site } from "../data/site";
---

<section id="spazi" class="py-20 px-4 section-alt">
  <div class="max-w-6xl mx-auto">
    <SectionHeader title={site.spaces.title} subtitle={site.spaces.subtitle} />

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      {
        site.spaces.items.map((space) => (
          <div class="card bg-base-100 shadow-md hover:shadow-lg transition-shadow duration-300 overflow-hidden">
            {/* Placeholder immagine — sostituire con <img src={space.image}> quando disponibili */}
            <figure class="h-48 relative" aria-hidden="true">
              <div
                class="absolute inset-0"
                style={`background: linear-gradient(135deg, ${space.type === "flex-desk" ? "oklch(0.637 0.292 12)" : "oklch(0.25 0.01 260)"} 0%, ${space.type === "flex-desk" ? "oklch(0.45 0.2 12)" : "oklch(0.15 0.005 260)"} 100%);`}
              >
                <div class="absolute inset-0 flex items-center justify-center">
                  {space.type === "flex-desk" ? (
                    // Shared Desk Icon: Two users at a desk
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-16 w-16 text-white/50"
                      fill="none"
                      viewBox="0 0 48 48"
                      stroke="currentColor"
                      stroke-width="1"
                    >
                      <rect
                        x="10"
                        y="32"
                        width="28"
                        height="6"
                        rx="2"
                        fill="currentColor"
                        class="text-white/50"
                      />
                      <rect
                        x="14"
                        y="20"
                        width="20"
                        height="8"
                        rx="2"
                        stroke="currentColor"
                        stroke-width="2"
                        fill="none"
                      />
                      <circle
                        cx="18"
                        cy="16"
                        r="3"
                        stroke="currentColor"
                        stroke-width="2"
                        fill="none"
                      />
                      <circle
                        cx="30"
                        cy="16"
                        r="3"
                        stroke="currentColor"
                        stroke-width="2"
                        fill="none"
                      />
                    </svg>
                  ) : (
                    // Private Office Icon: Door + single desk
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-16 w-16 text-white/50"
                      fill="none"
                      viewBox="0 0 48 48"
                      stroke="currentColor"
                      stroke-width="1"
                    >
                      <rect
                        x="12"
                        y="16"
                        width="24"
                        height="22"
                        rx="3"
                        stroke="currentColor"
                        stroke-width="2"
                        fill="none"
                      />
                      <rect
                        x="18"
                        y="28"
                        width="12"
                        height="4"
                        rx="1"
                        fill="currentColor"
                        class="text-white/50"
                      />
                      <rect
                        x="22"
                        y="19"
                        width="4"
                        height="7"
                        rx="1"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                      />
                      <circle cx="32" cy="27" r="1" fill="currentColor" />
                    </svg>
                  )}
                </div>
              </div>
            </figure>

            <div class="card-body">
              <h3 class="card-title text-xl">{space.title}</h3>
              <p class="text-base-content/70">{space.description}</p>

              <ul class="mt-4 space-y-2">
                {space.features.map((feature) => (
                  <li class="flex items-center gap-2 text-sm">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-4 w-4 text-primary shrink-0"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M4.5 12.75l6 6 9-13.5"
                      />
                    </svg>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>

              <div class="card-actions mt-6">
                <a href="#contatti" class="btn btn-primary w-full">
                  {space.ctaLabel}
                </a>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
