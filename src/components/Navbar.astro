---
import { site } from "../data/site";
---

<header
  class="navbar bg-base-100/95 backdrop-blur-sm sticky top-0 z-50 shadow-sm px-4"
>
  <div class="max-w-6xl mx-auto w-full flex items-center justify-between gap-4">
    <a href="/" class="shrink-0" aria-label={`${site.name} - Homepage`}>
      <img src={site.logo} alt={`${site.name} logo`} class="h-32 w-auto" />
    </a>

    <nav
      class="hidden lg:flex items-center gap-1"
      aria-label="Navigazione principale"
    >
      {
        site.nav.map((item) => (
          <a href={item.href} class="btn btn-ghost btn-sm">
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a href="#contatti" class="btn btn-primary btn-sm hidden sm:inline-flex">
        Contattaci
      </a>

      <div class="lg:hidden dropdown dropdown-end">
        <div
          tabindex="0"
          role="button"
          class="btn btn-ghost btn-square"
          aria-label="Apri menu"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
          </svg>
        </div>
        <ul
          tabindex="0"
          class="dropdown-content menu bg-base-100 rounded-box z-10 w-52 p-2 shadow-lg mt-2"
        >
          {
            site.nav.map((item) => (
              <li>
                <a href={item.href}>{item.label}</a>
              </li>
            ))
          }
          <li class="sm:hidden">
            <a href="#contatti" class="text-primary font-medium">Contattaci</a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</header>
